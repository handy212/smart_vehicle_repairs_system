# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vehicle_repairs_db

# Redis (for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Twilio (SMS / Voice fallback — leave blank if unused; placeholders are ignored)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional alternative to TWILIO_PHONE_NUMBER for SMS
TWILIO_MESSAGING_SERVICE_SID=
# Preferred SMS provider when admin sms_provider is unset: hubtel | twilio | infobip | mock
SMS_SERVICE=hubtel
SMS_ENABLED=False

# Infobip SMS (optional)
INFOBIP_BASE_URL=
INFOBIP_API_KEY=
INFOBIP_SENDER_ID=
# HTTP Basic credentials configured on the Infobip delivery-report subscription
INFOBIP_WEBHOOK_USERNAME=
INFOBIP_WEBHOOK_PASSWORD=

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# CarAPI (for vehicle data)
CARAPI_KEY=your-carapi-key
CARAPI_SECRET=your-carapi-secret

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Payment Gateway (example: Stripe)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Site Configuration
SITE_NAME=Smart Vehicle Repairs
SITE_URL=http://localhost:8000
# Public frontend URL (QuickBooks OAuth redirect uses {FRONTEND_BASE_URL}/api/quickbooks/callback/)
FRONTEND_BASE_URL=http://localhost:3000
# QuickBooks Online — prefer Admin → Integrations (SystemSettings). Env seeds those settings.
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_SANDBOX_ENABLED=true
# QUICKBOOKS_AUTO_SYNC_ENABLED=true
# QUICKBOOKS_SYNC_INLINE=true
# Optional explicit OAuth callback (must match Intuit app Redirect URIs exactly)
# QBO_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback/

# Firebase Push Notifications
FIREBASE_ENABLED=True
FIREBASE_CREDENTIALS_PATH=firebase/your-project-firebase-adminsdk.json

# Gemini AI (Google) — prefer Admin → Integrations. Env seeds/fallback only.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-lite-latest

# Keep false unless a Celery worker is running and monitored.
SYSTEM_BACKUP_ASYNC=False

# Browser Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=admin@example.com

# Hubtel SMS (Ghana)
HUBTEL_CLIENT_ID=your-client-id
HUBTEL_CLIENT_SECRET=your-client-secret
HUBTEL_FROM=Vehicle Repairs
HUBTEL_SMS_ENABLED=False

# Meta WhatsApp Cloud API (optional — staff can still use manual wa.me without this)
# Approve message templates in Meta Business Manager for business-initiated sends.
WHATSAPP_ENABLED=False
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# SITE_URL must be publicly reachable so Meta can fetch signed PDF links.

# Hubtel Payment Gateway (Ghana)
HUBTEL_MERCHANT_ID=your-merchant-id
HUBTEL_API_KEY=your-api-key
HUBTEL_API_SECRET=your-api-secret
HUBTEL_PAYMENT_ENABLED=False
HUBTEL_SANDBOX=True

# Paystack Payment Gateway (Ghana)
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PAYMENT_ENABLED=False
HUBTEL_PAYMENT_ENABLED=False
HUBTEL_SANDBOX=True

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here
