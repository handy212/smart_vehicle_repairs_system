# ========================================
# Smart Vehicle Repairs System
# Production Environment Variables
# ========================================
# Copy this file to .env.production and fill in your values

# Django Settings
DJANGO_ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-script
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# Database
DB_NAME=svr_db
DB_USER=svr_user
DB_PASSWORD=your-secure-database-password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# Redis
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# API URL
API_URL=https://api.yourdomain.com/api

# Public frontend URL (used in email template links such as {site_url})
FRONTEND_BASE_URL=https://yourdomain.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT Tokens (in minutes)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# SMS Configuration (Hubtel)
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_FROM=YourCompany
HUBTEL_SMS_ENABLED=False

# Firebase (Optional)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
FIREBASE_ENABLED=False

# AWS S3 (Optional — media storage and/or backups)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Offsite backups (optional — requires AWS CLI on production server)
# Example: s3://your-bucket/svr-backups
BACKUP_S3_URI=
BACKUP_RETENTION_DAYS=30
BACKUP_ALERT_WEBHOOK_URL=
BACKUP_ALERT_SLACK_WEBHOOK_URL=
BACKUP_ALERT_EMAIL=

# Error tracking (optional — Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# System backups via admin UI (requires Celery worker)
SYSTEM_BACKUP_ASYNC=True

# Production integration defaults (override only when testing sandboxes)
QUICKBOOKS_SANDBOX_ENABLED=False
QUICKBOOKS_SYNC_INLINE=False
HUBTEL_SANDBOX=False
NOTIFICATIONS_ASYNC=True
